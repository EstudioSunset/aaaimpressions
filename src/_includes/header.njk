<header id="top" data-header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="mx-auto max-w-6xl px-5">
    <div class="flex items-center justify-between h-[72px]">

      <!-- Brand -->
      <a href="{{ '/' if lang == 'es' else '/en/' }}" class="flex items-center gap-3" aria-label="AAA Impressions — Inicio">
        <img src="/assets/img/logo.png" alt="AAA Impressions" width="180" height="36" class="h-9 w-auto">
        <div class="leading-none hidden sm:block">
          <p class="text-xs text-gray-400">{{ "Marketing Digital" if lang == "es" else "Digital Marketing" }}</p>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-5 xl:gap-7 text-sm font-medium text-gray-600" aria-label="{{ 'Navegación principal' if lang == 'es' else 'Main navigation' }}">
        {% if lang == "es" %}
          <a class="nav-link hover:text-gray-900 transition-colors" href="/es/servicios/">Servicios</a>
          <a class="nav-link hover:text-gray-900 transition-colors" href="/es/ubicaciones/">Ubicaciones</a>
          <a class="nav-link hover:text-gray-900 transition-colors" href="/es/blog/">Blog</a>
          <a class="nav-link hover:text-gray-900 transition-colors" href="/es/paquetes/">Paquetes</a>
          <a class="nav-link hover:text-gray-900 transition-colors" href="/es/sobre-nosotros/">Nosotros</a>
          <a class="nav-link hover:text-gray-900 transition-colors" href="/es/contacto/">Contacto</a>
        {% else %}
          <a class="nav-link hover:text-gray-900 transition-colors" href="/en/services/">Services</a>
          <a class="nav-link hover:text-gray-900 transition-colors" href="/en/locations/">Locations</a>
          <a class="nav-link hover:text-gray-900 transition-colors" href="/en/blog/">Blog</a>
          <a class="nav-link hover:text-gray-900 transition-colors" href="/en/packages/">Packages</a>
          <a class="nav-link hover:text-gray-900 transition-colors" href="/en/about/">About</a>
          <a class="nav-link hover:text-gray-900 transition-colors" href="/en/contact/">Contact</a>
        {% endif %}
      </nav>

      <!-- Right controls -->
      <div class="flex items-center gap-3">

        <!-- Language switch — links to the other-language twin of the current page -->
        <div class="flex items-center rounded-xl border border-gray-200 bg-white overflow-hidden text-xs font-semibold">
          <a href="{{ hreflangEs }}"
             class="lang-btn px-3 py-1.5 {{ 'active' if lang == 'es' else 'text-gray-500 hover:text-gray-700' }}"
             hreflang="es" aria-label="Versión en español">ES</a>
          <a href="{{ hreflangEn }}"
             class="lang-btn px-3 py-1.5 {{ 'active' if lang == 'en' else 'text-gray-500 hover:text-gray-700' }}"
             hreflang="en" aria-label="English version">EN</a>
        </div>

        <!-- CTA -->
        <a href="{{ site.whatsapp }}?text={{ 'Hola%2C%20me%20gustar%C3%ADa%20una%20consulta%20gratuita%20sobre%20marketing%20digital.' if lang == 'es' else 'Hello%2C%20I%20would%20like%20a%20free%20consultation%20about%20digital%20marketing.' }}"
           target="_blank" rel="noopener noreferrer"
           class="hidden sm:inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity"
           style="background:var(--primary)">
          {{ "Consulta gratis" if lang == "es" else "Free consult" }}
        </a>

        <!-- Mobile menu button -->
        <button id="menuBtn"
                class="lg:hidden p-2 rounded-xl border border-gray-200 bg-white hover:bg-gray-50 transition"
                aria-label="{{ 'Abrir menú' if lang == 'es' else 'Open menu' }}"
                aria-expanded="false"
                aria-controls="mobileMenu">
          <svg id="iconOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="iconClose" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

      </div>
    </div>

    <!-- Mobile nav -->
    <div id="mobileMenu" class="hidden lg:hidden pb-4">
      <nav class="rounded-2xl border border-gray-100 bg-white shadow-lg p-3 grid gap-1 text-sm"
           aria-label="{{ 'Menú móvil' if lang == 'es' else 'Mobile menu' }}">
        {% if lang == "es" %}
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/es/servicios/">Servicios</a>
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/es/ubicaciones/">Ubicaciones</a>
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/es/blog/">Blog</a>
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/es/paquetes/">Paquetes</a>
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/es/sobre-nosotros/">Nosotros</a>
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/es/contacto/">Contacto</a>
          <a class="mt-2 px-4 py-3 rounded-xl text-white text-center font-semibold hover:opacity-90 transition-opacity"
             style="background:var(--primary)"
             href="{{ site.whatsapp }}?text=Hola%2C%20me%20gustar%C3%ADa%20una%20consulta%20gratuita."
             target="_blank" rel="noopener noreferrer">Consulta gratis por WhatsApp</a>
        {% else %}
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/en/services/">Services</a>
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/en/locations/">Locations</a>
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/en/blog/">Blog</a>
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/en/packages/">Packages</a>
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/en/about/">About</a>
          <a class="px-4 py-2.5 rounded-xl hover:bg-gray-50 font-medium transition" href="/en/contact/">Contact</a>
          <a class="mt-2 px-4 py-3 rounded-xl text-white text-center font-semibold hover:opacity-90 transition-opacity"
             style="background:var(--primary)"
             href="{{ site.whatsapp }}?text=Hello%2C%20I%20would%20like%20a%20free%20consultation."
             target="_blank" rel="noopener noreferrer">Free WhatsApp consult</a>
        {% endif %}
      </nav>
    </div>
  </div>
</header>
