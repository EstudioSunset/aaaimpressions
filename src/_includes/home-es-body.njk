<style>
.kpi-panel {
  position: relative;
  background:
    linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px),
    rgba(13,33,64,0.52);
  background-size: 30px 30px, 30px 30px, auto;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(232,80,0,0.24);
  border-radius: 18px;
  padding: 20px;
  overflow: hidden;
}
.kpi-halo {
  position: absolute;
  inset: 0;
  background: radial-gradient(300px circle at var(--mx,50%) var(--my,50%), rgba(232,80,0,0.22) 0%, rgba(0,87,231,0.09) 48%, transparent 68%);
  opacity: 0;
  transition: opacity 0.35s ease;
  pointer-events: none;
  z-index: 1;
  border-radius: 18px;
}
.kpi-panel:hover .kpi-halo { opacity: 1; }
@keyframes kpi-scan {
  0%   { top: -3px; opacity: 0; }
  6%   { opacity: 1; }
  88%  { opacity: 0.8; }
  100% { top: 108%; opacity: 0; }
}
.kpi-scan-line {
  position: absolute;
  left: 0; right: 0; height: 1.5px;
  background: linear-gradient(90deg, transparent, rgba(232,80,0,0.95) 30%, rgba(0,87,231,0.95) 70%, transparent);
  box-shadow: 0 0 10px rgba(232,80,0,0.65), 0 0 22px rgba(0,87,231,0.38);
  animation: kpi-scan 4.2s ease-in-out infinite;
  z-index: 5; pointer-events: none;
}
@keyframes kpi-pulse {
  0%,100% { opacity:1; transform:scale(1); }
  50%     { opacity:0.3; transform:scale(0.72); }
}
.kpi-live-dot {
  width:7px; height:7px; border-radius:50%; background:#22c55e;
  box-shadow:0 0 6px rgba(34,197,94,0.65);
  animation: kpi-pulse 1.4s ease-in-out infinite; flex-shrink:0;
}
@keyframes kpi-bar-grow {
  from { transform: scaleY(0); }
  to   { transform: scaleY(1); }
}
.kpi-bar {
  transform-origin: bottom; border-radius: 2px;
  animation: kpi-bar-grow 1s cubic-bezier(.22,1,.36,1) both;
}
.kpi-bar:nth-child(1){animation-delay:.05s}
.kpi-bar:nth-child(2){animation-delay:.15s}
.kpi-bar:nth-child(3){animation-delay:.25s}
.kpi-bar:nth-child(4){animation-delay:.35s}
.kpi-bar:nth-child(5){animation-delay:.45s}
.kpi-bar:nth-child(6){animation-delay:.55s}
.kpi-bar:nth-child(7){animation-delay:.65s}
@keyframes kpi-draw {
  from { stroke-dashoffset: 520; }
  to   { stroke-dashoffset: 0; }
}
.kpi-line-path {
  stroke-dasharray: 520; stroke-dashoffset: 520;
  animation: kpi-draw 2.2s cubic-bezier(.4,0,.2,1) 0.5s both;
}
@keyframes kpi-circle {
  from { stroke-dashoffset: 107; }
  to   { stroke-dashoffset: 26; }
}
.kpi-circle-bar {
  stroke-dasharray: 107; stroke-dashoffset: 107;
  animation: kpi-circle 1.9s cubic-bezier(.4,0,.2,1) 1.1s both;
}
@keyframes kpi-float-a {
  0%,100% { transform: translateY(0); }
  50%     { transform: translateY(-6px); }
}
@keyframes kpi-float-b {
  0%,100% { transform: translateY(0); }
  50%     { transform: translateY(-5px); }
}
.kpi-badge-a { animation: kpi-float-a 3.8s ease-in-out infinite; }
.kpi-badge-b { animation: kpi-float-b 4.4s ease-in-out 0.9s infinite; }
@keyframes kpi-fade-up {
  from { opacity:0; transform:translateY(5px); }
  to   { opacity:1; transform:translateY(0); }
}
.kpi-v1{animation:kpi-fade-up .7s ease .25s both}
.kpi-v2{animation:kpi-fade-up .7s ease .45s both}
.kpi-v3{animation:kpi-fade-up .7s ease .65s both}
</style>

