<!doctype html>
<html lang="{{ lang }}">
<head>

<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga4 }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '{{ site.ga4 }}');
</script>

<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','{{ site.gtm }}');</script>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />


{% set canonicalHref = canonicalUrl or site.baseUrl + page.url %}
<title>{{ title }}</title>
<meta name="description" content="{{ metaDescription }}" />
<link rel="canonical" href="{{ canonicalHref }}" />
{% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}

<!-- hreflang -->
<link rel="alternate" hreflang="es"        href="{{ site.baseUrl }}{{ hreflangEs }}" />
<link rel="alternate" hreflang="en"        href="{{ site.baseUrl }}{{ hreflangEn }}" />
<link rel="alternate" hreflang="x-default" href="{{ site.baseUrl }}{{ hreflangEs }}" />

<!-- Open Graph -->
<meta property="og:title"       content="{{ title }}" />
<meta property="og:description" content="{{ metaDescription }}" />
<meta property="og:type"        content="website" />
<meta property="og:url"         content="{{ canonicalHref }}" />
<meta property="og:locale"      content="{{ 'es_US' if lang == 'es' else 'en_US' }}" />
<meta property="og:image"       content="{{ site.baseUrl }}{{ ogImage or site.ogImage }}" />
<meta property="og:image:type"  content="image/webp" />
<meta property="og:site_name"   content="AAA Impressions" />

<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content="{{ title }}" />
<meta name="twitter:description" content="{{ metaDescription }}" />
<meta name="twitter:image"       content="{{ site.baseUrl }}{{ ogImage or site.ogImage }}" />

<!-- Meta Pixel -->
<script>
!function(f,b,e,v,n,t,s)
{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};
if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];
s.parentNode.insertBefore(t,s)}(window,document,'script',
'https://connect.facebook.net/en_US/fbevents.js');
fbq('init','1566944181625416');
fbq('track','PageView');
</script>
<noscript><img height="1" width="1" style="display:none"
src="https://www.facebook.com/tr?id=1566944181625416&ev=PageView&noscript=1"
/></noscript>
<!-- End Meta Pixel -->

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- Compiled CSS -->
<link rel="stylesheet" href="/assets/css/main.css" />

<!-- Structured Data -->
{% if schema == "home" %}{% include "schema/local-business.njk" %}{% endif %}
{% if schema == "service" %}{% include "schema/service.njk" %}{% endif %}

{% if site.hubspot and site.hubspot.portalId %}
<!-- HubSpot tracking code -->
<script type="text/javascript" id="hs-script-loader" async defer src="//js-{{ site.hubspot.region }}.hs-scripts.com/{{ site.hubspot.portalId }}.js"></script>
{% endif %}
<!-- MailerLite Universal -->
<script>
(function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
.push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
(window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
ml('account', '2443554');
</script>
<!-- End MailerLite Universal -->

</head>
<body>

<!-- Animated site background -->
<div id="site-bg" aria-hidden="true">
  <div id="sb-base"></div>
  <canvas id="sb-canvas"></canvas>
</div>

<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ site.gtm }}"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<!-- Skip to content -->
<a href="#main-content"
   class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[999] focus:bg-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg focus:text-sm focus:font-medium">
  {{ "Saltar al contenido" if lang == "es" else "Skip to content" }}
</a>

{% include "header.njk" %}

<main id="main-content">
{{ content | safe }}
</main>

{% include "footer.njk" %}

<script src="/assets/js/main.js"></script>
</body>
</html>
