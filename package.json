{
  "name": "aaaimpressions-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/assets/css/main.css -o ./_site/assets/css/main.css --minify",
    "build:11ty": "eleventy",
    "build": "npm run build:11ty && npm run build:css",
    "dev:css": "tailwindcss -i ./src/assets/css/main.css -o ./_site/assets/css/main.css --watch",
    "dev:11ty": "eleventy --serve --port 8080",
    "dev": "concurrently \"npm run dev:11ty\" \"npm run dev:css\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^3.4.0"
  }
}
